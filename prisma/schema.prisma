// Department Digital Platform (DDP) - Prisma Schema
// Built for UNILAG Physics Department

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Supports both local file: SQLite and Turso libsql:// URLs.
  // Set DATABASE_URL (or TURSO_DATABASE_URL) in your environment.
  url = env("DATABASE_URL")
}

// ============ AUTH & USERS ============

model Student {
  id                  String   @id @default(cuid())
  matricNumber        String   @unique
  fullName            String
  level               String   // 100, 200, 300, 400, 500
  programme           String   // BSc Physics, BSc Astrophysics, etc.
  email               String?
  phone               String?
  password            String?
  isVerified          Boolean  @default(false)
  verificationStatus  String   @default("pending") // pending, submitted, approved, rejected
  idDocumentUrl       String?
  hasVoted            Boolean  @default(false)
  // Device fingerprint of the browser that claimed this account. Used to
  // prevent one device from claiming multiple matrics (mass fraud defence).
  deviceFingerprint   String?
  // IP address recorded at claim time for audit / dispute resolution.
  claimIp             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  activities          Activity[]
  verificationLogs    VerificationLog[]
  votes               Vote[]
  allowlistEntry      MatricAllowlist?
}

// Pre-loaded voter register: every valid matric + name uploaded by class reps
// via attendance lists. A student can only claim an account if their matric
// exists here AND is unclaimed. This replaces the old "pre-seeded Student
// rows" model and the email-OTP flow.
model MatricAllowlist {
  id           String   @id @default(cuid())
  matricNumber String   @unique
  fullName     String
  programme    String   // Physics Education, Biology Education, etc.
  level        String   // 100, 200, 300, 400
  cohort       String   // e.g. "Physics Education" — derived from programme
  isClaimed    Boolean  @default(false)
  claimedAt    DateTime?
  claimedByStudentId String? @unique // links to Student once claimed
  uploadBatch  String   // groups entries from the same upload
  uploadedAt   DateTime @default(now())
  // Pre-set password hash, computed at upload time using the ULSESA rule:
  //   matricNumber + last4(lowercase(surname))
  // Students log in directly with this — no claim/set-password flow.
  // NULL only for entries uploaded before this field existed (backfilled by /api/admin/migrate).
  passwordHash String?

  student      Student? @relation(fields: [claimedByStudentId], references: [id], onDelete: SetNull)
}

// Fraud reports. When a student finds their matric already claimed by someone
// else, they file a dispute. The admin reviews and can revoke the fraudulent
// claim, freeing the matric for the real student to re-claim.
model Dispute {
  id            String   @id @default(cuid())
  matricNumber  String   // the disputed matric
  expectedName  String   // the real student's name (from allowlist)
  reporterName  String   // who is reporting (self-reported)
  reporterContact String? // optional email/phone for follow-up
  reason        String   // free text
  status        String   @default("pending") // pending, resolved_revoked, resolved_dismissed
  accusedStudentId String? // the student who fraudulently claimed
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?  // admin id
  resolutionNote String?
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin") // admin, superadmin
  createdAt DateTime @default(now())

  auditLogs   AuditLog[]
  verificationActions VerificationLog[]
}

// ============ ELECTION ============

model Election {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("upcoming") // upcoming, active, ended, cancelled
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions   Position[]
  votes       Vote[]
}

model Position {
  id          String   @id @default(cuid())
  title       String
  description String?
  electionId  String
  order       Int      @default(0)
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  candidates  Candidate[]
  votes       Vote[]
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  positionId  String
  manifesto   String?
  photoUrl    String?
  level       String?
  programme   String?
  bio         String?
  isVerified  Boolean  @default(true)
  voteCount   Int      @default(0)
  createdAt   DateTime @default(now())

  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  votes       Vote[]
}

model Vote {
  id          String   @id @default(cuid())
  electionId  String
  positionId  String
  candidateId String
  studentId   String   // stored for one-vote-per-student enforcement, but not displayed publicly
  timestamp   DateTime @default(now())
  // Anonymous 8-char receipt code the student can use to confirm their vote
  // was recorded — without revealing WHO they voted for. Unique across all
  // votes so it can be looked up publicly.
  receiptCode String   @unique
  // Anonymous: no relation back to student identity in public views

  election    Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  position    Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, positionId]) // one vote per student per position
}

// ============ CONTENT ============

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general") // general, academic, election, event
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String
  location    String?
  category    String   @default("upcoming") // upcoming, past
  createdAt   DateTime @default(now())
}

model Course {
  id             String   @id @default(cuid())
  code           String   @unique
  title          String
  level          String
  semester       String   // First, Second
  description    String?
  department     String   @default("General") // Biology Edu, Chemistry Edu, Mathematics Edu, Physics Edu, Integrated Science Edu, General
  googleDriveUrl String?  // Google Drive folder link containing course materials
  createdAt      DateTime @default(now())

  resources      Resource[]
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  type        String   // note, past_question, textbook, slides, video
  url         String
  description String?
  courseId     String?
  createdAt   DateTime @default(now())

  course      Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ============ TRANSPARENCY & AUDIT ============

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // approve_student, reject_student, start_election, end_election, etc.
  target    String?  // what was acted upon
  details   String?
  timestamp DateTime @default(now())

  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model VerificationLog {
  id          String   @id @default(cuid())
  studentId   String
  adminId     String?
  action      String   // submitted, approved, rejected
  notes       String?
  timestamp   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  admin       Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
}

model Activity {
  id          String   @id @default(cuid())
  studentId   String
  action      String   // account_verified, downloaded_notes, voted, etc.
  details     String?
  timestamp   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ============ COMMUNITY ============

model CommunityGroup {
  id            String   @id @default(cuid())
  title         String
  description   String?
  category      String   @default("general") // general, level, department, sports, academic, announcement
  whatsappLink  String   // WhatsApp group invite link
  memberCount   Int      @default(0)
  createdAt     DateTime @default(now())
}
